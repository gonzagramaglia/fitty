{
  "name": "fitty",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "@temporalio/activity": "^1.18.1",
    "@temporalio/client": "^1.18.1",
    "@temporalio/worker": "^1.18.1",
    "@temporalio/workflow": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo": "~56.0.12",
    "expo-av": "^16.0.8",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "^56.0.18",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-status-bar": "~56.0.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "lucide-react-native": "^1.22.0",
    "nativewind": "^4.2.6",
    "openai": "^6.45.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-chart-kit": "^7.0.1",
    "react-native-reanimated": "^4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "^0.10.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@react-native/jest-preset": "^0.86.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "~19.2.2",
    "husky": "9.1.7",
    "jest": "^30.4.2",
    "jest-expo": "^56.0.5",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "description": "An AI-powered cat health tracker that estimates Body Condition Score (BCS) from just 2 photos. Features voice context analysis, historical trends, and personalized recommendations. Built for #HACKTHEKITTY 2026 🐾 Tech Stack: React Native, Supabase, Temporal.io, Claude, Whisper & Aikido Security.",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "start:worker": "npx tsx temporal/worker.ts",
    "start:backend": "npx tsx temporal/server.ts",
    "temporal:worker": "npx tsx temporal/worker.ts",
    "prepare": "husky"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react",
            "strict": false
          }
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ]
  },
  "private": true
}
